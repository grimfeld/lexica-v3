{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    {
      "identifier": "sql:allow-execute",
      "allow": [{ "path": "sqlite:lexica.db" }]
    },
    "dialog:default",
    "fs:default"
  ]
}
